# Copy to .env for local development

# Your Anthropic API key — get it at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Access code to protect your app (set anything you like, e.g. "dawaclear2026")
# Leave empty or unset to disable auth (anyone can use the app)
ACCESS_CODE=your-secret-code-here
